{
  "name": "cicd-node-app",
  "version": "1.0.0",
  "description": "GitOps Mail System - Secure CI/CD Pipeline Demo Application",
  "main": "app.js",
  "author": "GitOps Lab",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Benjamin-yankey/Gitops_lab.git"
  },
  "keywords": [
    "nodejs",
    "express",
    "cicd",
    "gitops",
    "security",
    "docker",
    "aws",
    "ecs",
    "pipeline"
  ],
  
  "scripts": {
    "start": "node app.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "dev": "nodemon app.js",
    "docker:build": "docker build -t cicd-node-app .",
    "docker:run": "docker run -p 5000:5000 cicd-node-app"
  },
  
  "dependencies": {
    "express": "^4.22.1"
  },
  
  "devDependencies": {
    "eslint": "^8.57.1",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  },
  
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  
  "eslintConfig": {
    "env": {
      "node": true,
      "es2021": true,
      "jest": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": 12,
      "sourceType": "module"
    },
    "rules": {
      "no-console": "off",
      "no-unused-vars": ["error", { "argsIgnorePattern": "^_" }]
    }
  },
  
  "overrides": {
    "minimatch": "^5.1.6",
    "glob": "^8.1.0",
    "tar": "^6.2.1"
  }
}
